<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PomoDone.Pages.DecksPage"
             Title="Flashcards">
    <VerticalStackLayout Padding="30" Spacing="12" VerticalOptions="Center">
        <Label Text="Flashcards" Style="{StaticResource Headline}" HorizontalOptions="Center" />
        <Label Text="Deck list goes here (Day 6)." HorizontalOptions="Center" />
        <Button Text="Open Deck Detail (route test)" Clicked="OnDeckDetailClicked" />
        <Button Text="Open Review (route test)" Clicked="OnReviewClicked" />
    </VerticalStackLayout>
</ContentPage>
