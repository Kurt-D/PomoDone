<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PomoDone.ViewModels"
             x:Class="PomoDone.Pages.ReviewPage"
             x:DataType="vm:ReviewViewModel"
             Title="Review"
             BackgroundColor="{AppThemeBinding Light={StaticResource VantaBgLight}, Dark={StaticResource VantaBgDark}}">

    <Grid Padding="20" RowDefinitions="Auto,*,Auto" RowSpacing="16">

        <Label Grid.Row="0"
               Text="{Binding Progress}"
               IsVisible="{Binding IsReviewing}"
               Style="{StaticResource VantaLabelMuted}"
               HorizontalOptions="Center" />

        <!-- Reviewing: the card (tap to flip). Front face gets the neutral
             CardFaceFront background; the back face swaps to CardFaceBack via
             the DataTrigger on ShowingBack so the side is obvious at a glance.
             Both are XAML AppThemeBinding tokens → they re-theme live, and the
             swap is visual only (flip state stays in ShowingBack; §4.3). -->
        <Border Grid.Row="1"
                IsVisible="{Binding IsReviewing}"
                Style="{StaticResource VantaCard}"
                Padding="24"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardFaceFrontLight}, Dark={StaticResource CardFaceFrontDark}}">
            <VerticalStackLayout VerticalOptions="Center" Spacing="10">
                <Label Text="{Binding FaceLabel}"
                       HorizontalOptions="Center"
                       FontSize="12"
                       Style="{StaticResource VantaLabelMuted}" />
                <Label Text="{Binding CurrentFace}"
                       FontSize="24"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       Style="{StaticResource VantaLabelPrimary}" />
                <Label Text="Tap to flip"
                       HorizontalOptions="Center"
                       FontSize="11"
                       Style="{StaticResource VantaLabelFaint}" />
            </VerticalStackLayout>
            <Border.Triggers>
                <DataTrigger TargetType="Border"
                             Binding="{Binding ShowingBack}"
                             Value="True">
                    <Setter Property="BackgroundColor"
                            Value="{AppThemeBinding Light={StaticResource CardFaceBackLight}, Dark={StaticResource CardFaceBackDark}}" />
                </DataTrigger>
            </Border.Triggers>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding FlipCommand}" />
            </Border.GestureRecognizers>
        </Border>

        <!-- Complete end state -->
        <VerticalStackLayout Grid.Row="1"
                             IsVisible="{Binding IsComplete}"
                             VerticalOptions="Center"
                             Spacing="12">
            <Label Text="Review complete"
                   FontSize="22"
                   FontAttributes="Bold"
                   Style="{StaticResource VantaLabelPrimary}"
                   HorizontalOptions="Center" />
            <Label Text="{Binding CompleteSummary}"
                   Style="{StaticResource VantaLabelMuted}"
                   HorizontalOptions="Center" />
            <Button Text="Back to deck"
                    Command="{Binding BackToDeckCommand}"
                    Style="{StaticResource VantaSecondaryButton}"
                    HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- Empty deck -->
        <VerticalStackLayout Grid.Row="1"
                             IsVisible="{Binding ShowNoCards}"
                             VerticalOptions="Center"
                             Spacing="12">
            <Label Text="No cards to review"
                   FontSize="18"
                   FontAttributes="Bold"
                   Style="{StaticResource VantaLabelPrimary}"
                   HorizontalOptions="Center" />
            <Label Text="Add some cards to this deck first."
                   Style="{StaticResource VantaLabelMuted}"
                   HorizontalOptions="Center" />
            <Button Text="Back to deck"
                    Command="{Binding BackToDeckCommand}"
                    Style="{StaticResource VantaSecondaryButton}"
                    HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- Reviewing: grade buttons. Colours come from the GradePositive /
             GradeNegative tokens. Dark is LOCKED to the prior look (Got it amber,
             Missed it muted-grey), so each binding keeps its Dark value and only
             the Light side takes the green/red hue (inspo). Missed it keeps the
             surface-alt grey in Dark rather than the token's magenta Dark, to
             avoid a Dark-mode regression. -->
        <Grid Grid.Row="2"
              IsVisible="{Binding IsReviewing}"
              ColumnDefinitions="*,*"
              ColumnSpacing="12">
            <Button Grid.Column="0"
                    Text="Missed it"
                    Command="{Binding MissedItCommand}"
                    Style="{StaticResource VantaSelectorPill}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource GradeNegativeLight}, Dark={StaticResource VantaSurfaceAltDark}}"
                    TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource VantaTextMutedDark}}"
                    HeightRequest="48" />
            <Button Grid.Column="1"
                    Text="Got it"
                    Command="{Binding GotItCommand}"
                    Style="{StaticResource VantaAddTaskButton}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource GradePositiveLight}, Dark={StaticResource GradePositiveDark}}"
                    TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Black}}"
                    HeightRequest="48" />
        </Grid>

    </Grid>

</ContentPage>
