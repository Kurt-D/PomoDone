<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PomoDone.ViewModels"
             x:Class="PomoDone.Pages.TasksPage"
             x:DataType="vm:TasksViewModel"
             Title="Tasks">

    <Grid RowDefinitions="Auto,*" Padding="16" RowSpacing="12">

        <!-- Add task -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <Entry Grid.Column="0"
                   Placeholder="New task title"
                   Text="{Binding NewTaskTitle}"
                   ReturnCommand="{Binding AddTaskCommand}" />
            <Button Grid.Column="1"
                    Text="Add"
                    Command="{Binding AddTaskCommand}" />
        </Grid>

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Tasks}"
                        SelectionMode="None">
            <CollectionView.EmptyView>
                <Label Text="No tasks yet. Add one above."
                       HorizontalOptions="Center"
                       Margin="0,40,0,0" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:TaskRowViewModel">
                    <!-- CheckBox (done) and 📌 (favorite) stay inline as direct
                         controls; Set/Clear Active, Edit, Delete live in the "⋮"
                         action sheet. No swipe gesture to compete with these
                         controls; each Button consumes its own tap. -->
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                          ColumnSpacing="8"
                          Padding="4,8">
                        <CheckBox Grid.Column="0"
                                  VerticalOptions="Center"
                                  IsChecked="{Binding IsDone, Mode=TwoWay}" />
                        <Label Grid.Column="1"
                               VerticalOptions="Center"
                               Text="{Binding Title}"
                               FontSize="16">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label"
                                             Binding="{Binding IsDone}"
                                             Value="True">
                                    <Setter Property="TextDecorations" Value="Strikethrough" />
                                    <Setter Property="TextColor" Value="{StaticResource Gray400}" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                        <Button Grid.Column="2"
                                Text="📌"
                                FontSize="20"
                                Opacity="{Binding FavoriteOpacity}"
                                BackgroundColor="Transparent"
                                Clicked="OnToggleFavoriteClicked"
                                CommandParameter="{Binding .}" />
                        <Button Grid.Column="3"
                                Text="⋮"
                                FontSize="22"
                                WidthRequest="48"
                                BackgroundColor="Transparent"
                                TextColor="{StaticResource Gray600}"
                                Clicked="OnTaskMenuClicked"
                                CommandParameter="{Binding .}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>
