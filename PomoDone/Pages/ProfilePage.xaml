<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PomoDone.ViewModels"
             xmlns:models="clr-namespace:PomoDone.Models"
             x:Class="PomoDone.Pages.ProfilePage"
             x:DataType="vm:ProfileViewModel"
             Title="Profile">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Avatar -->
            <Border StrokeShape="RoundRectangle 60"
                    HeightRequest="120"
                    WidthRequest="120"
                    HorizontalOptions="Center">
                <Image Source="{Binding AvatarSource}"
                       Aspect="AspectFill"
                       HeightRequest="120"
                       WidthRequest="120">
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding PickAvatarCommand}" />
                    </Image.GestureRecognizers>
                </Image>
            </Border>
            <Label Text="Tap the avatar to change it"
                   FontSize="12"
                   TextColor="{StaticResource Gray400}"
                   HorizontalOptions="Center" />

            <!-- Display name -->
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Entry Grid.Column="0"
                       Placeholder="Display name"
                       Text="{Binding DisplayName}" />
                <Button Grid.Column="1"
                        Text="Save"
                        Command="{Binding SaveNameCommand}" />
            </Grid>

            <!-- Derived stats -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto"
                  ColumnSpacing="12" RowSpacing="12">

                <Border Grid.Row="0" Grid.Column="0" Padding="14" StrokeShape="RoundRectangle 10">
                    <VerticalStackLayout>
                        <Label Text="Level" FontSize="12" TextColor="{StaticResource Gray400}" />
                        <Label Text="{Binding Level}" FontSize="28" FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="0" Grid.Column="1" Padding="14" StrokeShape="RoundRectangle 10">
                    <VerticalStackLayout>
                        <Label Text="Points" FontSize="12" TextColor="{StaticResource Gray400}" />
                        <Label Text="{Binding Points}" FontSize="28" FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="1" Grid.Column="0" Padding="14" StrokeShape="RoundRectangle 10">
                    <VerticalStackLayout>
                        <Label Text="Current streak" FontSize="12" TextColor="{StaticResource Gray400}" />
                        <Label Text="{Binding StreakDisplay}" FontSize="28" FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" Padding="14" StrokeShape="RoundRectangle 10">
                    <VerticalStackLayout>
                        <Label Text="Focus purity" FontSize="12" TextColor="{StaticResource Gray400}" />
                        <Label Text="{Binding FocusPurity}" FontSize="28" FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="2" Grid.Column="0" Padding="14" StrokeShape="RoundRectangle 10">
                    <VerticalStackLayout>
                        <Label Text="Focus sessions" FontSize="12" TextColor="{StaticResource Gray400}" />
                        <Label Text="{Binding CompletedFocusSessions}" FontSize="28" FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="2" Grid.Column="1" Padding="14" StrokeShape="RoundRectangle 10">
                    <VerticalStackLayout>
                        <Label Text="Days active" FontSize="12" TextColor="{StaticResource Gray400}" />
                        <Label Text="{Binding DaysActive}" FontSize="28" FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Padding="14" StrokeShape="RoundRectangle 10">
                    <VerticalStackLayout>
                        <Label Text="Cards reviewed this week" FontSize="12" TextColor="{StaticResource Gray400}" />
                        <Label Text="{Binding ReviewsThisWeek}" FontSize="28" FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Badges -->
            <Label Text="Badges" FontSize="18" FontAttributes="Bold" />
            <CollectionView ItemsSource="{Binding Badges}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Badge">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="12"
                              Padding="4,8"
                              Opacity="{Binding DisplayOpacity}">
                            <Label Grid.Column="0"
                                   Text="{Binding Icon}"
                                   FontSize="28"
                                   VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                <Label Text="{Binding Name}" FontAttributes="Bold" />
                                <Label Text="{Binding Description}"
                                       FontSize="12"
                                       TextColor="{StaticResource Gray400}" />
                            </VerticalStackLayout>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
