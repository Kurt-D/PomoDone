<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PomoDone.ViewModels"
             xmlns:models="clr-namespace:PomoDone.Models"
             x:Class="PomoDone.Pages.ProfilePage"
             x:DataType="vm:ProfileViewModel"
             Title="Profile">

    <ContentPage.Resources>
        <!-- Small unobtrusive "ⓘ" tap target. Its own hit area, so a tap opens
             the alert and nothing else (stat tiles have no row-tap behavior). -->
        <Style x:Key="InfoButton" TargetType="Button">
            <Setter Property="Text" Value="&#x24D8;" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="WidthRequest" Value="28" />
            <Setter Property="HeightRequest" Value="28" />
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="TextColor" Value="{StaticResource Gray400}" />
            <Setter Property="VerticalOptions" Value="Start" />
            <Setter Property="HorizontalOptions" Value="End" />
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Avatar -->
            <Border StrokeShape="RoundRectangle 60"
                    HeightRequest="120"
                    WidthRequest="120"
                    HorizontalOptions="Center">
                <Image Source="{Binding AvatarSource}"
                       Aspect="AspectFill"
                       HeightRequest="120"
                       WidthRequest="120">
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding PickAvatarCommand}" />
                    </Image.GestureRecognizers>
                </Image>
            </Border>
            <Label Text="Tap the avatar to change it"
                   FontSize="12"
                   TextColor="{StaticResource Gray400}"
                   HorizontalOptions="Center" />

            <!-- Display name — display mode by default (read-only Label + pencil);
                 the editable Entry only exists while IsEditing, so no keyboard
                 pops on page load. -->
            <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="8"
                  HorizontalOptions="Center"
                  IsVisible="{Binding IsNotEditing}">
                <Label Grid.Column="0"
                       Text="{Binding DisplayNameOrPlaceholder}"
                       FontSize="18"
                       FontAttributes="Bold"
                       VerticalOptions="Center" />
                <Button Grid.Column="1"
                        Text="&#x270E;"
                        FontSize="16"
                        Padding="0"
                        WidthRequest="36"
                        HeightRequest="36"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource Gray600}"
                        Command="{Binding BeginEditNameCommand}" />
            </Grid>

            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8"
                  IsVisible="{Binding IsEditing}">
                <Entry Grid.Column="0"
                       Placeholder="Display name"
                       Text="{Binding NameEditBuffer}" />
                <Button Grid.Column="1"
                        Text="&#x2713;"
                        FontSize="18"
                        WidthRequest="48"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource Primary}"
                        Command="{Binding ConfirmEditNameCommand}" />
                <Button Grid.Column="2"
                        Text="&#x2715;"
                        FontSize="18"
                        WidthRequest="48"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource Gray600}"
                        Command="{Binding CancelEditNameCommand}" />
            </Grid>

            <!-- Derived stats -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto"
                  ColumnSpacing="12" RowSpacing="12">

                <Border Grid.Row="0" Grid.Column="0" Padding="14" StrokeShape="RoundRectangle 10">
                    <VerticalStackLayout>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Level" FontSize="12" TextColor="{StaticResource Gray400}" VerticalOptions="Center" />
                            <Button Grid.Column="1" Style="{StaticResource InfoButton}"
                                    Command="{Binding ShowInfoCommand}" CommandParameter="Level" />
                        </Grid>
                        <Label Text="{Binding Level}" FontSize="28" FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="0" Grid.Column="1" Padding="14" StrokeShape="RoundRectangle 10">
                    <VerticalStackLayout>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Points" FontSize="12" TextColor="{StaticResource Gray400}" VerticalOptions="Center" />
                            <Button Grid.Column="1" Style="{StaticResource InfoButton}"
                                    Command="{Binding ShowInfoCommand}" CommandParameter="Points" />
                        </Grid>
                        <Label Text="{Binding Points}" FontSize="28" FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="1" Grid.Column="0" Padding="14" StrokeShape="RoundRectangle 10">
                    <VerticalStackLayout>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Current streak" FontSize="12" TextColor="{StaticResource Gray400}" VerticalOptions="Center" />
                            <Button Grid.Column="1" Style="{StaticResource InfoButton}"
                                    Command="{Binding ShowInfoCommand}" CommandParameter="Streak" />
                        </Grid>
                        <Label Text="{Binding StreakDisplay}" FontSize="28" FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" Padding="14" StrokeShape="RoundRectangle 10">
                    <VerticalStackLayout>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Time in App vs Away" FontSize="12" TextColor="{StaticResource Gray400}" VerticalOptions="Center" />
                            <Button Grid.Column="1" Style="{StaticResource InfoButton}"
                                    Command="{Binding ShowInfoCommand}" CommandParameter="Purity" />
                        </Grid>
                        <Label Text="{Binding FocusPurity}" FontSize="28" FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="2" Grid.Column="0" Padding="14" StrokeShape="RoundRectangle 10">
                    <VerticalStackLayout>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Focus sessions" FontSize="12" TextColor="{StaticResource Gray400}" VerticalOptions="Center" />
                            <Button Grid.Column="1" Style="{StaticResource InfoButton}"
                                    Command="{Binding ShowInfoCommand}" CommandParameter="Sessions" />
                        </Grid>
                        <Label Text="{Binding CompletedFocusSessions}" FontSize="28" FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="2" Grid.Column="1" Padding="14" StrokeShape="RoundRectangle 10">
                    <VerticalStackLayout>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Days active" FontSize="12" TextColor="{StaticResource Gray400}" VerticalOptions="Center" />
                            <Button Grid.Column="1" Style="{StaticResource InfoButton}"
                                    Command="{Binding ShowInfoCommand}" CommandParameter="DaysActive" />
                        </Grid>
                        <Label Text="{Binding DaysActive}" FontSize="28" FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="3" Grid.Column="0" Padding="14" StrokeShape="RoundRectangle 10">
                    <VerticalStackLayout>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Cards reviewed this week" FontSize="12" TextColor="{StaticResource Gray400}" VerticalOptions="Center" />
                            <Button Grid.Column="1" Style="{StaticResource InfoButton}"
                                    Command="{Binding ShowInfoCommand}" CommandParameter="Reviews" />
                        </Grid>
                        <Label Text="{Binding ReviewsThisWeek}" FontSize="28" FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="3" Grid.Column="1" Padding="14" StrokeShape="RoundRectangle 10">
                    <VerticalStackLayout>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Streak freezes" FontSize="12" TextColor="{StaticResource Gray400}" VerticalOptions="Center" />
                            <Button Grid.Column="1" Style="{StaticResource InfoButton}"
                                    Command="{Binding ShowInfoCommand}" CommandParameter="Freezes" />
                        </Grid>
                        <Label Text="{Binding FreezesAvailable}" FontSize="28" FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Badges -->
            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0" Text="Badges" FontSize="18" FontAttributes="Bold" VerticalOptions="Center" />
                <Button Grid.Column="1" Style="{StaticResource InfoButton}"
                        Command="{Binding ShowInfoCommand}" CommandParameter="Badges" />
            </Grid>
            <CollectionView ItemsSource="{Binding Badges}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Badge">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="12"
                              Padding="4,8"
                              Opacity="{Binding DisplayOpacity}">
                            <Label Grid.Column="0"
                                   Text="{Binding Icon}"
                                   FontSize="28"
                                   VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                <Label Text="{Binding Name}" FontAttributes="Bold" />
                                <Label Text="{Binding Description}"
                                       FontSize="12"
                                       TextColor="{StaticResource Gray400}" />
                            </VerticalStackLayout>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
