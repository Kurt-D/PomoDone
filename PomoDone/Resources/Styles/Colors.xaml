<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <Color x:Key="Primary">#512BD4</Color>
    <Color x:Key="PrimaryDark">#ac99ea</Color>
    <Color x:Key="PrimaryDarkText">#242424</Color>
    <Color x:Key="Secondary">#DFD8F7</Color>
    <Color x:Key="SecondaryDarkText">#9880e5</Color>
    <Color x:Key="Tertiary">#2B0B98</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Magenta">#D600AA</Color>
    <Color x:Key="MidnightBlue">#190649</Color>
    <Color x:Key="OffBlack">#1f1f1f</Color>

    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>

    <!-- ============================================================= -->
    <!-- Vanta theme tokens — THEME-AWARE pairs. Consumers bind via       -->
    <!-- {AppThemeBinding Light=...Light, Dark=...Dark}.                  -->
    <!--   Dark = mono-amber identity (LOCKED — do not change).          -->
    <!--   Light = clean light scheme, primary red/coral, per            -->
    <!--           docs/design/LightModeInspo.jpg.                        -->
    <!-- ============================================================= -->
    <Color x:Key="VantaBgDark">#111111</Color>            <!-- app screen background -->
    <Color x:Key="VantaBgLight">#F5F6F8</Color>
    <Color x:Key="VantaSurfaceDark">#1A1A1A</Color>       <!-- card surface -->
    <Color x:Key="VantaSurfaceLight">#FFFFFF</Color>
    <Color x:Key="VantaSurfaceAltDark">#1D1D1D</Color>    <!-- pill / secondary surface -->
    <Color x:Key="VantaSurfaceAltLight">#EFEFF2</Color>
    <Color x:Key="VantaAccentDark">#F59E0B</Color>        <!-- accent (Dark amber / Light red-coral) -->
    <Color x:Key="VantaAccentLight">#FF3B30</Color>
    <Color x:Key="VantaTextDark">#FFFFFF</Color>          <!-- primary text -->
    <Color x:Key="VantaTextLight">#1A1A1A</Color>
    <Color x:Key="VantaTextMutedDark">#8A8A8A</Color>     <!-- secondary / muted text -->
    <Color x:Key="VantaTextMutedLight">#8A8F98</Color>
    <Color x:Key="VantaTextFaintDark">#555555</Color>     <!-- faint label (e.g. FOCUS) -->
    <Color x:Key="VantaTextFaintLight">#B0B4BC</Color>
    <Color x:Key="VantaRingTrackDark">#222222</Color>     <!-- countdown ring track -->
    <Color x:Key="VantaRingTrackLight">#FFE0DE</Color>

    <!-- ============================================================= -->
    <!-- Multicolor DATA tokens — paired Dark/Light like the Vanta set.  -->
    <!-- Dark value = current mono colour (so Dark is visually unchanged);-->
    <!-- Light value = the real hue. Consumed by C# render sites in a    -->
    <!-- LATER step (charts via StatsChartFactory, heatmap via the        -->
    <!-- converter); GradePositive/GradeNegative also feed the ReviewPage -->
    <!-- grade buttons in XAML now. Declared here only this step.         -->
    <!-- ============================================================= -->
    <Color x:Key="ChartWeeklyDark">#F59E0B</Color>        <!-- Weekly Trend line -->
    <Color x:Key="ChartWeeklyLight">#FF3B30</Color>
    <Color x:Key="ChartPeakDark">#F59E0B</Color>          <!-- Peak Hour bars -->
    <Color x:Key="ChartPeakLight">#2F6BFF</Color>
    <Color x:Key="Heat0Dark">#1D1D1D</Color>              <!-- heatmap intensity ramp 0..4 -->
    <Color x:Key="Heat0Light">#EBEDF0</Color>
    <Color x:Key="Heat1Dark">#5C3D08</Color>
    <Color x:Key="Heat1Light">#C6E9C9</Color>
    <Color x:Key="Heat2Dark">#8A5C0A</Color>
    <Color x:Key="Heat2Light">#8FD694</Color>
    <Color x:Key="Heat3Dark">#C2820B</Color>
    <Color x:Key="Heat3Light">#4CAF50</Color>
    <Color x:Key="Heat4Dark">#F59E0B</Color>
    <Color x:Key="Heat4Light">#2E9E40</Color>
    <Color x:Key="GradePositiveDark">#F59E0B</Color>      <!-- "Got it"  (Dark amber / Light green) -->
    <Color x:Key="GradePositiveLight">#34C759</Color>
    <Color x:Key="GradeNegativeDark">#D600AA</Color>      <!-- "Missed it" hue (Dark magenta / Light red) -->
    <Color x:Key="GradeNegativeLight">#FF3B30</Color>

    <!-- Review-mode card faces — front vs back get distinct backgrounds so the
         viewer can tell at a glance which side they're on (§4.3; visual only).
         Dark stays WITHIN the mono-amber identity (neutral surface vs amber-
         tinted surface — no second hue introduced); Light is multicolor
         (calm neutral front vs soft green back, reusing the heat-ramp green).
         Consumed by ReviewPage's single card Border, switched on ShowingBack
         via a DataTrigger — both sides are XAML AppThemeBinding so they
         re-theme live (no C#-resolved stale-colour issue). -->
    <Color x:Key="CardFaceFrontDark">#1A1A1A</Color>     <!-- = VantaSurfaceDark (neutral card surface) -->
    <Color x:Key="CardFaceFrontLight">#FFFFFF</Color>    <!-- calm neutral surface -->
    <Color x:Key="CardFaceBackDark">#5C3D08</Color>      <!-- amber-tinted surface (mono-amber, clearly distinct) -->
    <Color x:Key="CardFaceBackLight">#C6E9C9</Color>     <!-- soft green -->
</ResourceDictionary>